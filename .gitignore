.vs/
.vscode/
*.user
*.suo
*.sln
*.vcxproj
*.filters

# 4. OS Specific
[Dd]s.[Ss]tore
Thumbs.db

# 5. External Source Cleanup
externals/**/build/
externals/**/*.zip